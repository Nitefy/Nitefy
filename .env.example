# ─── Firebase (frontend) ────────────────────────────────────────────────────
# Obtén estos valores en: Firebase Console → tu proyecto → Configuración → Aplicaciones web
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Contacto (perfil del cliente) ──────────────────────────────────────────
VITE_WHATSAPP=34TUNUMERO
VITE_EMAIL=tu-email@outlook.com

# ─── Firebase Admin (solo Netlify Functions — NO pongas VITE_ aquí) ─────────
# Obtén estos en: Firebase Console → Configuración → Cuentas de servicio → Generar nueva clave privada
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Stripe (solo Netlify Functions) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs de los Payment Links de Stripe (la parte tras /p/ en la URL del link)
# Ejemplo: si tu link es https://buy.stripe.com/abc123, el ID es "plink_abc123"
# Encuéntralo en Stripe Dashboard → Payment Links → tu link → pestaña Metadata
STRIPE_LINK_ID_ESENCIAL=plink_...
STRIPE_LINK_ID_COMPLETO=plink_...
STRIPE_LINK_ID_TOTAL=plink_...
